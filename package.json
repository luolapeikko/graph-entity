{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "graph-entity-root",
	"version": "0.0.1",
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"repository": "github:luolapeikko/graph-entity",
	"keywords": [
		"typescript",
		"graph",
		"node",
		"edge"
	],
	"author": "mharj",
	"license": "MIT",
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@tsconfig/node20": "^20.1.9",
		"@types/node": "^24.12.4",
		"@vitest/coverage-v8": "^4.1.7",
		"c8": "^11.0.0",
		"lefthook": "^2.1.9",
		"prettier": "^3.8.3",
		"tsdown": "^0.22.1",
		"tslib": "^2.8.1",
		"typedoc": "^0.28.19",
		"typedoc-plugin-dt-links": "^2.0.57",
		"typedoc-plugin-mdn-links": "^5.1.1",
		"typescript": "^6.0.3",
		"vite": "^8.0.14",
		"vitest": "^4.1.7"
	},
	"scripts": {
		"prepare": "lefthook install",
		"build": "pnpm -r run build",
		"pretest": "pnpm -r run build",
		"lint": "biome check",
		"lint:fix": "biome check --write",
		"test": "vitest run --typecheck --coverage",
		"coverage": "vitest test --typecheck --run --no-isolate --reporter=dot --coverage --coverage.reporter=lcov",
		"validate": "pnpm -r run validate",
		"docs": "typedoc --options typedoc.json --tsconfig tsconfig.workspace.json"
	},
	"packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800"
}
