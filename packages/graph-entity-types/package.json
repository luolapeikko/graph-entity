{
	"name": "@luolapeikko/graph-entity-types",
	"version": "0.2.0",
	"description": "Typess for Graph Entity module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		"import": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		},
		"require": {
			"types": "./dist/index.d.cts",
			"default": "./dist/index.cjs"
		},
		"default": "./dist/index.mjs"
	},
	"scripts": {
		"build": "tsdown src/index.ts --sourcemap --format cjs,esm --dts --clean -c tsconfig.build.json",
		"validate": "tsc --noEmit"
	},
	"files": [
		"dist"
	],
	"repository": "github:luolapeikko/graph-entity",
	"keywords": [
		"typescript",
		"graph",
		"node",
		"edge"
	],
	"author": "mharj",
	"license": "MIT",
	"peerDependencies": {
		"events": ">=3.3.0"
	}
}
